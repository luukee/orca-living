{%- comment -%} Hide bar on paths (comma-separated; from first announcement block or section). Fallback: /blogs/landscapes when store data lacks setting. {%- endcomment -%}
{%- assign hide_paths_setting = section.settings.hide_on_paths -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'announcement' and hide_paths_setting == blank -%}
    {%- assign hide_paths_setting = block.settings.hide_on_paths -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}
{%- assign show_bar = true -%}
{%- for hide_path in hide_paths_setting  -%}
  {%- assign p = hide_path | strip -%}
  {%- if p != blank -%}
    {%- assign p_slash = p | append: '/' -%}
    {%- if request.path == p or request.path == p_slash or request.path contains p_slash -%}
      {%- assign show_bar = false -%}
      {%- break -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- if show_bar and request.path == '/blogs/landscapes' or request.path contains '/blogs/landscapes/' -%}
  {%- assign show_bar = false -%}
{%- endif -%}

{%- comment -%} Count announcement blocks to decide single vs rotating. {%- endcomment -%}
{%- assign announcement_block_count = 0 -%}
{%- for b in section.blocks -%}
  {%- if b.type == 'announcement' -%}
    {%- assign announcement_block_count = announcement_block_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- if show_bar -%}
{%- if announcement_block_count >= 2 -%}
  <div class="announcement-bar__rotating" data-rotation-delay-ms="{{ section.settings.rotation_interval_seconds | default: 3 | times: 1000 }}" data-section-id="{{ section.id }}">
{%- endif -%}
{%- assign announcement_index = 0 -%}
{%- for block in section.blocks -%}
  {%- case block.type -%}
    {%- when 'announcement' -%}
      <div class="announcement-bar color-{{ block.settings.color_scheme }} gradient" role="region" aria-label="{{ 'sections.header.announcement' | t }}" data-announcement-bar-id="{{ section.id }}-{{ block.id }}" data-announcement-index="{{ announcement_index }}" {{ block.shopify_attributes }}>
        <div class="page-width announcement-bar__inner">
          <div class="announcement-bar__message-wrap">
            {%- if block.settings.text != blank -%}
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="announcement-bar__link link link--text focus-inset animate-arrow">
              {%- endif -%}
              <p class="announcement-bar__message {{ block.settings.text_alignment }} h4" style="color: {{ block.settings.text_color }};">
                <span>{{ block.settings.text | escape }}</span>
                {%- if block.settings.link != blank -%}
                  {% render 'icon-arrow' %}
                {%- endif -%}
              </p>
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if block.settings.show_close_button -%}
            <button type="button" class="announcement-bar__close" aria-label="{{ 'accessibility.close' | t }}">
              {% render 'icon-close' %}
            </button>
          {%- endif -%}
        </div>
      </div>
      {%- assign announcement_index = announcement_index | plus: 1 -%}
  {%- endcase -%}
{%- endfor -%}
{%- if announcement_block_count >= 2 -%}
  </div>
{%- endif -%}
{%- endif -%}

{%- if show_bar -%}
<style>
  .announcement-bar__inner {
    display: flex;
    align-items: center;
  }
  .announcement-bar__message-wrap {
    flex: 1 1 auto;
    min-width: 0;
  }
  .announcement-bar__close {
    flex-shrink: 0;
    padding: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #000;
    opacity: 0.8;
  }
  .announcement-bar__close:hover {
    opacity: 1;
  }
  .announcement-bar__close .icon {
    display: block;
    width: 1.2rem;
    height: 1.2rem;
  }
  .announcement-bar.is-dismissed {
    display: none;
  }
  /* Rotating mode: one bar visible at a time; transition only on content so background doesn't flash. */
  .announcement-bar__rotating {
    position: relative;
  }
  .announcement-bar__rotating .announcement-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    pointer-events: none;
    transition: none;
  }
  .announcement-bar__rotating .announcement-bar.is-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }
  .announcement-bar__rotating .announcement-bar .announcement-bar__inner {
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .announcement-bar__rotating .announcement-bar.is-active .announcement-bar__inner {
    opacity: 1;
  }
  .announcement-bar__rotating.is-dismissed {
    display: none;
  }
</style>
<script>
  (function () {
    var prefix = 'announcement-bar-dismissed-';
    var rotatingPrefix = 'announcement-bar-rotating-dismissed-';

    /** Hide dismissed bars from localStorage and attach close/dismiss behaviour. */
    function init() {
      var rotating = document.querySelector('.announcement-bar__rotating');
      if (rotating) {
        var sectionId = rotating.getAttribute('data-section-id');
        if (sectionId && localStorage.getItem(rotatingPrefix + sectionId)) {
          rotating.classList.add('is-dismissed');
        } else {
          var bars = rotating.querySelectorAll('.announcement-bar');
          if (bars.length) {
            bars[0].classList.add('is-active');
            var delayMs = parseInt(rotating.getAttribute('data-rotation-delay-ms'), 10) || 3000;
            var currentIndex = 0;
            setInterval(function () {
              bars[currentIndex].classList.remove('is-active');
              currentIndex = (currentIndex + 1) % bars.length;
              bars[currentIndex].classList.add('is-active');
            }, delayMs);
          }
        }
      }

      /* Per-bar dismiss: only for bars NOT inside a rotating container. */
      document.querySelectorAll('.announcement-bar[data-announcement-bar-id]').forEach(function (bar) {
        if (bar.closest('.announcement-bar__rotating')) return;
        var id = bar.getAttribute('data-announcement-bar-id');
        if (id && localStorage.getItem(prefix + id)) {
          bar.classList.add('is-dismissed');
        }
      });

      document.addEventListener('click', function (e) {
        var btn = e.target.closest('.announcement-bar__close');
        if (!btn) return;
        var bar = btn.closest('.announcement-bar');
        if (!bar) return;
        var rotating = bar.closest('.announcement-bar__rotating');
        if (rotating) {
          var sectionId = rotating.getAttribute('data-section-id');
          if (sectionId) {
            try { localStorage.setItem(rotatingPrefix + sectionId, '1'); } catch (err) {}
            rotating.classList.add('is-dismissed');
          }
          return;
        }
        var id = bar.getAttribute('data-announcement-bar-id');
        if (id) {
          try { localStorage.setItem(prefix + id, '1'); } catch (err) {}
          bar.classList.add('is-dismissed');
        }
      });
    }
    /* Run init synchronously so dismissed bars are hidden before first paint (avoids flash on refresh/navigation). */
    init();
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "textarea",
      "id": "hide_on_paths",
      "label": "Hide on paths",
      "info": "Comma-separated paths where the announcement bar is hidden (e.g. /blogs/landscapes). Matches exact path and any path below it.",
      "placeholder": "/blogs/landscapes"
    },
    {
      "type": "range",
      "id": "rotation_interval_seconds",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 3,
      "unit": "sec",
      "label": "Rotation interval",
      "info": "When multiple announcements exist, time between switching to the next (single announcement unchanged)."
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome to our store",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type":"color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "options": [
            {
              "value": "left",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__1.label"
            },
            {
              "value": "center",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__2.label"
            },
            {
              "value": "right",
              "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.options__3.label"
            }
          ],
          "default": "center",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text_alignment.label"
        },
        {
          "type": "select",
          "id": "color_scheme",
          "options": [
            {
              "value": "accent-1",
              "label": "t:sections.all.colors.accent_1.label"
            },
            {
              "value": "accent-2",
              "label": "t:sections.all.colors.accent_2.label"
            },
            {
              "value": "background-1",
              "label": "t:sections.all.colors.background_1.label"
            },
            {
              "value": "background-2",
              "label": "t:sections.all.colors.background_2.label"
            },
            {
              "value": "inverse",
              "label": "t:sections.all.colors.inverse.label"
            }
          ],
          "default": "accent-1",
          "label": "t:sections.all.colors.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        },
        {
          "type": "checkbox",
          "id": "show_close_button",
          "label": "Show close button",
          "default": true
        },
        {
          "type": "textarea",
          "id": "hide_on_paths",
          "label": "Hide bar on paths",
          "info": "Comma-separated paths where the announcement bar is hidden (e.g. /blogs/landscapes). Used when this section is inside the header group.",
          "placeholder": "/blogs/landscapes"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
